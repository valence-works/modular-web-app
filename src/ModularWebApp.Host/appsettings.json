{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Nuplane": {
    "Setup": {
      "AutomaticReconciliation": true,
      "PollInterval": "00:00:10",
      "Feeds": [
        {
          "Name": "local-packages",
          "DirectoryPath": "packages",
          "IncludePatterns": [
            "ModularWebApp.Module.*"
          ],
          "Directory": {
            "Watch": true,
            "DebounceWindow": "00:00:01"
          }
        }
      ]
    },
    "Loading": {
      "Enabled": true,
      "SharedAssemblies": [
        {
          "Name": "CShells.Abstractions"
        },
        {
          "Name": "CShells.AspNetCore.Abstractions"
        }
      ]
    }
  },
  "CShells": {
    "Shells": [
      {
        "Name": "Default",
        "Features": [
          "Greetings"
        ],
        "Configuration": {
          "WebRouting": {
            "Path": ""
          }
        }
      },
      {
        "Name": "Northwind",
        "Features": [
          "Greetings",
          "Time"
        ],
        "Configuration": {
          "WebRouting": {
            "Path": "northwind"
          }
        }
      },
      {
        "Name": "Fabrikam",
        "Features": [
          "Time"
        ],
        "Configuration": {
          "WebRouting": {
            "Path": "fabrikam"
          }
        }
      }
    ]
  },
  "AllowedHosts": "*"
}
